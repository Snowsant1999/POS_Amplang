        android:supportsRtl="true"
        android:theme="@style/Theme.POSAmplang">
        <activity
            android:name=".activities.auth.LoginActivity"
            android:exported="true"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.auth.RegisterActivity"
            android:exported="true"
            android:screenOrientation="landscape" />
        <activity
            android:name=".activities.auth.LupaSandiActivity"
            android:exported="true"
            android:screenOrientation="landscape" />
        <activity
            android:name=".activities.dashboard.MainActivity"
            android:exported="true"
            android:screenOrientation="landscape" />
        <activity
            android:name=".activities.transaksi.KasirActivity"
            android:exported="false"
            android:screenOrientation="landscape" />
        <activity
            android:name=".activities.supplier.SupplierListActivity"
            android:exported="false"
            android:screenOrientation="landscape" />
        <activity
            android:name=".activities.supplier.SupplierDetailActivity"

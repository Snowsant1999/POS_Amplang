            android:name=".activities.laporan.LaporanHarianDetailActivity"
            android:exported="false"
            android:screenOrientation="landscape" />
        <activity
            android:name=".activities.pengaturan.PengaturanActivity"
            android:exported="false"
            android:screenOrientation="landscape" />
        <activity
            android:name=".activities.produk.ProdukListActivity"
            android:exported="false"
            android:screenOrientation="landscape" />
        <activity
            android:name=".activities.produk.TambahProdukActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.POSAmplang.Translucent" />

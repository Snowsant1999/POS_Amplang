<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/tv_nama_supplier"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:text="Indah Abdi"
        android:textColor="#2196F3" />

    <TextView
        android:id="@+id/tv_kontak"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="087698092547" />

    <TextView
        android:id="@+id/tv_alamat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Banjarmasin" />

    <TextView
        android:id="@+id/tv_email"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:text="indaahabdii77@gmail.com" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="60dp"
        android:layout_height="30dp"
        android:background="@drawable/bg_status_aktif"
        android:gravity="center"
        android:text="Aktif"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold" />
    <LinearLayout
        android:layout_width="95dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            android:layout_width="44dp"
            android:layout_height="30dp"
            android:layout_marginEnd="4dp"
            android:backgroundTint="@color/action_blue"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="Edit"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="9sp"
            app:cornerRadius="6dp"
            app:icon="@drawable/ic_edit"
            app:iconPadding="1dp"
            app:iconSize="9dp"
            app:iconTint="@color/white" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="2dp"
            android:background="@drawable/bg_delete"
            android:contentDescription="Hapus Supplier"
            android:padding="7dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_delete"
            app:tint="@color/primary_red" />

    </LinearLayout>
</LinearLayout>
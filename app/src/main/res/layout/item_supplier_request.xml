<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <TextView android:id="@+id/tv_request_tanggal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="12sp" />
    <TextView android:id="@+id/tv_request_nomor" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.25" android:textSize="12sp" />
    <TextView android:id="@+id/tv_request_total" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="12sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_request_status"
            android:layout_width="78dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_status_diproses"
            android:gravity="center"
            android:text="Diproses"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.45"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_request_detail"
            android:layout_width="76dp"
            android:layout_height="38dp"
            android:backgroundTint="@color/primary_yellow"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="Detail"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="11sp"
            app:cornerRadius="5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_request_status"
            android:layout_width="76dp"
            android:layout_height="38dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/action_blue"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="Status"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="11sp"
            app:cornerRadius="5dp" />
    </LinearLayout>
</LinearLayout>

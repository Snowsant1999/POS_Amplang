<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="horizontal">

    <!-- Sidebar -->
    <include
        layout="@layout/layout_sidebar"
        android:layout_weight="1" />

    <!-- Main Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:text="LAPORAN HARIAN"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true"
                android:fadeScrollbars="false"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Table Header -->

                    <!-- Mock Data Rows for Preview -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#F2F2F2"
                        android:orientation="horizontal"
                        android:paddingVertical="12dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:paddingStart="12dp"
                            android:text="Tanggal"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="115dp"
                            android:layout_height="wrap_content"
                            android:text="Penjualan Awal"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="115dp"
                            android:layout_height="wrap_content"
                            android:text="Penjualan Tunai"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Uang Tunai"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="115dp"
                            android:layout_height="wrap_content"
                            android:text="Total Penjualan"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="65dp"
                            android:layout_height="wrap_content"
                            android:text="Cash"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="135dp"
                            android:layout_height="wrap_content"
                            android:text="Pembayaran Online"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="65dp"
                            android:layout_height="wrap_content"
                            android:text="BON"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="250dp"
                            android:layout_height="wrap_content"
                            android:text="Actions"
                            android:textColor="@color/black"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <include layout="@layout/item_laporan_harian" />
                    <include layout="@layout/item_laporan_harian_alt" />
                    <include layout="@layout/item_laporan_harian" />
                    <include layout="@layout/item_laporan_harian_alt" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvLaporanHarian"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Menampilkan 1 dari 5 data"
                android:textColor="#666666" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:background="@color/primary_yellow" android:gravity="center" android:text="1" android:textColor="@color/white" />
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginStart="8dp" android:background="#F2F2F2" android:gravity="center" android:text="2" android:textColor="@color/black" />
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginStart="8dp" android:background="#F2F2F2" android:gravity="center" android:text="3" android:textColor="@color/black" />
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginStart="8dp" android:background="#F2F2F2" android:gravity="center" android:text="4" android:textColor="@color/black" />
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_marginStart="12dp" android:src="@drawable/chevron_right" app:tint="@color/black" />
                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginStart="12dp" android:background="#DDDDDD" android:padding="8dp" android:src="@drawable/chevrons_left" app:tint="@color/white" />
                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginStart="4dp" android:background="#DDDDDD" android:padding="8dp" android:src="@drawable/chevrons_right" app:tint="@color/white" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/row_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <TextView android:id="@+id/tvTanggal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.1" android:textSize="13sp" />
    <TextView android:id="@+id/tvPemasukan" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.25" android:textSize="13sp" android:textStyle="bold" />
    <TextView android:id="@+id/tvPengeluaran" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.25" android:textSize="13sp" android:textStyle="bold" />
    <TextView android:id="@+id/tvSaldoBersih" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.25" android:textSize="13sp" android:textStyle="bold" />
    <TextView android:id="@+id/tvTransaksi" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.85" android:gravity="center" android:textSize="13sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.8"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLihat"
            android:layout_width="94dp"
            android:layout_height="38dp"
            android:backgroundTint="@color/primary_yellow"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="Lihat"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="11sp"
            app:cornerRadius="5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrint"
            android:layout_width="89dp"
            android:layout_height="38dp"
            android:layout_marginStart="7dp"
            android:backgroundTint="@color/action_blue"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:text="Excel"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="11sp"
            app:cornerRadius="5dp" />

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="7dp"
            android:background="@drawable/bg_delete_border"
            android:contentDescription="Hapus laporan"
            android:padding="10dp"
            android:src="@drawable/ic_delete"
            app:tint="@color/primary_red" />
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/row_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="10dp">

        <TextView
            android:id="@+id/tvTanggal"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:text="10/04/2026"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvPenjualanAwal"
            android:layout_width="115dp"
            android:layout_height="wrap_content"
            android:text="Rp0"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvPenjualanTunai"
            android:layout_width="115dp"
            android:layout_height="wrap_content"
            android:text="Rp0"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvUangTunai"
            android:layout_width="95dp"
            android:layout_height="wrap_content"
            android:text="Rp0"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTotalPenjualan"
            android:layout_width="105dp"
            android:layout_height="wrap_content"
            android:text="Rp0"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvCash"
            android:layout_width="65dp"
            android:layout_height="wrap_content"
            android:text="Rp0"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvPembayaranOnline"
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:text="Rp0"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvBon"
            android:layout_width="65dp"
            android:layout_height="wrap_content"
            android:text="Rp0"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btnLihat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/eye"
                    app:tint="@color/black" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Lihat"
                    android:textColor="@color/black"
                    android:textSize="13sp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPrint"
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@color/primary_yellow"
                android:text="Print"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnEdit"
                android:layout_width="65dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@color/action_blue"
                android:text="Edit"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_delete_border"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_delete"
                app:tint="@color/primary_red" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
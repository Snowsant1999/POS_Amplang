<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="480dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    app:cardCornerRadius="20dp"
    app:cardElevation="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="32dp"
        android:paddingTop="32dp"
        android:paddingBottom="28dp">

        <!-- Icon Status (sukses/gagal) -->
        <ImageView
            android:id="@+id/ivStatusIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:contentDescription="Status"
            android:src="@mipmap/berhasil_foreground" />

        <!-- Judul -->
        <TextView
            android:id="@+id/tvStatusTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Berhasil!"
            android:textColor="#8B1A1A"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Pesan -->
        <TextView
            android:id="@+id/tvStatusMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Pesan status."
            android:textColor="#555555"
            android:textSize="13sp"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp" />

        <!-- Tombol Aksi -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStatusAction"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#F0B429"
            android:text="OK"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            app:cornerRadius="12dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.produk.EditProdukActivity">

    <!-- Background blur menggunakan activity daftar produk -->
    <include layout="@layout/activity_produk_list" />
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <!-- Modal Dialog Edit -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="8dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Modal -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/action_blue"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/btnCloseEdit"
                    android:text="Edit Produk"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnCloseEdit"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Tutup"
                    android:src="@drawable/ic_close"
                    app:tint="@color/white" />
            </RelativeLayout>

            <!-- Body Modal -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Nama Produk -->
                    <TextView style="@style/LabelTabel" android:text="Nama Produk" />
                    <EditText
                        android:id="@+id/etNamaProdukEdit"
                        style="@style/InputTabel"
                        android:hint="Nama produk"
                        android:inputType="text"
                        android:importantForAutofill="no"
                        android:layout_marginBottom="12dp" />

                    <!-- Kategori -->
                    <TextView style="@style/LabelTabel" android:text="Kategori" />
                    <Spinner
                        android:id="@+id/spinnerKategoriEdit"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_spinner_border"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />

                    <!-- Harga Jual & Stok -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false"
                        android:weightSum="2"
                        android:layout_marginBottom="12dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="10dp"
                            android:orientation="vertical">
                            <TextView style="@style/LabelTabel" android:text="Harga Jual" />
                            <EditText
                                android:id="@+id/etHargaJualEdit"
                                style="@style/InputTabel"
                                android:hint="0"
                                android:inputType="number"
                                android:importantForAutofill="no" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView style="@style/LabelTabel" android:text="Stok" />
                            <EditText
                                android:id="@+id/etStokEdit"
                                style="@style/InputTabel"
                                android:hint="0"
                                android:inputType="number"
                                android:importantForAutofill="no" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Satuan -->
                    <TextView style="@style/LabelTabel" android:text="Satuan" />
                    <EditText
                        android:id="@+id/etSatuanEdit"
                        style="@style/InputTabel"
                        android:hint="Pcs"
                        android:inputType="text"
                        android:importantForAutofill="no"
                        android:layout_marginBottom="20dp" />

                    <!-- Tombol Aksi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBatalEdit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:backgroundTint="#E53935"
                            android:text="Batal"
                            android:textAllCaps="false"
                            android:layout_marginEnd="12dp"
                            app:cornerRadius="6dp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSimpanEdit"
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:backgroundTint="@color/action_blue"
                            android:text="Simpan"
                            android:textAllCaps="false"
                            app:cornerRadius="6dp" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>

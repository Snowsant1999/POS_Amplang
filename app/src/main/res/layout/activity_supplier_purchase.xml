<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_light"
    android:orientation="horizontal"
    tools:context=".activities.supplier.SupplierPurchaseActivity">

    <include
        layout="@layout/layout_sidebar"
        android:layout_width="160dp"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_purchase_header_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SUPPLIER / Nama Supplier / TAMBAH PEMBELIAN"
                android:textColor="@color/black"
                android:textSize="21sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_back_purchase"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Kembali"
                android:padding="10dp"
                android:src="@drawable/arrow"
                app:tint="@color/black" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="7dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_gray"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/iv_purchase_supplier_image"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_input_border"
                    android:padding="3dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/amplang_background" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_purchase_supplier_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Supplier"
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_purchase_supplier_phone"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.8"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_purchase_supplier_address"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.1"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_purchase_supplier_email"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.3"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_purchase_supplier_status"
                    android:layout_width="62dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_status_aktif"
                    android:gravity="center"
                    android:text="Aktif"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="14dp"
                android:layout_weight="0.82"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="7dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_gray"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/primary_yellow"
                        android:padding="12dp"
                        android:text="Pilih Produk Pembelian"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <RadioGroup
                                android:id="@+id/rg_purchase_item_type"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <RadioButton
                                    android:id="@+id/rb_purchase_existing"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:checked="true"
                                    android:text="Produk Tersedia" />

                                <RadioButton
                                    android:id="@+id/rb_purchase_new"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:text="Produk Baru" />
                            </RadioGroup>

                            <LinearLayout
                                android:id="@+id/container_existing_product"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="vertical">

                                <TextView style="@style/LabelTabel" android:text="Produk Supplier" />

                                <Spinner
                                    android:id="@+id/spinner_existing_product"
                                    android:layout_width="match_parent"
                                    android:layout_height="44dp"
                                    android:background="@drawable/bg_spinner_border" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/container_new_product"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView style="@style/LabelTabel" android:text="Nama Produk Baru" />

                                <EditText
                                    android:id="@+id/et_request_product_name"
                                    style="@style/InputTabel"
                                    android:hint="Masukkan nama produk"
                                    android:inputType="text" />

                                <TextView
                                    style="@style/LabelTabel"
                                    android:layout_marginTop="8dp"
                                    android:text="Kategori" />

                                <Spinner
                                    android:id="@+id/spinner_request_category"
                                    android:layout_width="match_parent"
                                    android:layout_height="44dp"
                                    android:background="@drawable/bg_spinner_border" />

                                <TextView
                                    style="@style/LabelTabel"
                                    android:layout_marginTop="8dp"
                                    android:text="Merek" />

                                <EditText
                                    android:id="@+id/et_request_brand"
                                    style="@style/InputTabel"
                                    android:hint="Masukkan merek"
                                    android:inputType="text" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:orientation="horizontal">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="8dp"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView style="@style/LabelTabel" android:text="Satuan" />

                                        <EditText
                                            android:id="@+id/et_request_unit"
                                            style="@style/InputTabel"
                                            android:hint="Bungkus"
                                            android:inputType="text" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView style="@style/LabelTabel" android:text="Harga Jual" />

                                        <EditText
                                            android:id="@+id/et_request_sell_price"
                                            style="@style/InputTabel"
                                            android:hint="Rp"
                                            android:inputType="number" />
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="8dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView style="@style/LabelTabel" android:text="Jumlah" />

                                    <EditText
                                        android:id="@+id/et_request_quantity"
                                        style="@style/InputTabel"
                                        android:hint="0"
                                        android:inputType="number" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView style="@style/LabelTabel" android:text="Harga Beli / Unit" />

                                    <EditText
                                        android:id="@+id/et_request_buy_price"
                                        style="@style/InputTabel"
                                        android:hint="Rp"
                                        android:inputType="number" />
                                </LinearLayout>
                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_add_request_item"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_marginTop="14dp"
                                android:backgroundTint="@color/action_blue"
                                android:text="+ Tambah ke Daftar"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                app:cornerRadius="5dp" />
                        </LinearLayout>
                    </ScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.18"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="7dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_gray"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/primary_yellow"
                        android:padding="12dp"
                        android:text="Daftar Produk Dipesan"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#F4F4F4"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="Produk" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:text="Tipe" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.5" android:gravity="center" android:text="Qty" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total" android:textStyle="bold" />
                        <View android:layout_width="30dp" android:layout_height="1dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@color/primary_red" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_purchase_draft"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        tools:listitem="@layout/item_purchase_draft" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border_gray" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tv_purchase_total"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Pembelian: Rp0"
                            android:textColor="@color/black"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_cancel_purchase"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:layout_marginEnd="10dp"
                            android:backgroundTint="#EEEEEE"
                            android:text="Batal"
                            android:textAllCaps="false"
                            android:textColor="@color/primary_red"
                            app:cornerRadius="5dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_submit_purchase"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:backgroundTint="@color/primary_red"
                            android:text="Buat Permintaan"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:cornerRadius="5dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

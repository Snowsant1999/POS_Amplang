<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="horizontal">

    <!-- Sidebar (Konsisten dengan Laporan Harian) -->
    <include
        layout="@layout/layout_sidebar"
        android:layout_weight="1" />

    <!-- Main Content Area -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="32dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENGATURAN"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/containerInfoToko"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvTitle"
            android:layout_marginTop="32dp"
            android:background="@drawable/border_gray_rounded"
            android:orientation="vertical">

            <!-- Header Informasi Toko -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F2F2F2"
                android:padding="16dp"
                android:text="INFORMASI TOKO"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD" />

            <!-- Nama Toko Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:padding="16dp">
                <TextView
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:text="Nama Toko:"
                    android:textColor="@color/black" />
                <TextView
                    android:id="@+id/valNamaToko"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Amplang Salsabila"
                    android:textColor="@color/black" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <!-- Alamat Toko Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F2F2F2"
                android:orientation="horizontal"
                android:padding="16dp">
                <TextView
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:text="Alamat Toko:"
                    android:textColor="@color/black" />
                <TextView
                    android:id="@+id/valAlamatToko"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Samarinda"
                    android:textColor="@color/black" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <!-- Email Toko Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:padding="16dp">
                <TextView
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:text="Email Toko:"
                    android:textColor="@color/black" />
                <TextView
                    android:id="@+id/valEmailToko"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="amplangsalsabila@gmail.com"
                    android:textColor="@color/black"
                    android:autoLink="email" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <!-- Nomor Telepon Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F2F2F2"
                android:orientation="horizontal"
                android:padding="16dp">
                <TextView
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:text="Nomor Telepon:"
                    android:textColor="@color/black" />
                <TextView
                    android:id="@+id/valNoTelp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="081273829217"
                    android:textColor="@color/black" />
            </LinearLayout>

        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/containerInfoToko"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@color/action_blue"
                android:paddingHorizontal="16dp"
                android:text="Edit"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:drawableStartCompat="@drawable/ic_edit"
                app:drawableTint="@color/white" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSimpan"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:background="@color/primary_yellow"
                android:paddingHorizontal="16dp"
                android:text="Simpan"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Logout -->
        <LinearLayout
            android:id="@+id/sidebarLogout"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/signout"
                app:tint="@color/primary_red" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Keluar"
                android:textColor="@color/primary_red"
                android:textStyle="bold" />
        </LinearLayout>

    </RelativeLayout>
</LinearLayout>
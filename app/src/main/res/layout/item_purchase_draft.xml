<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="8dp">

    <TextView android:id="@+id/tv_draft_nama" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:textStyle="bold" />
    <TextView android:id="@+id/tv_draft_tipe" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:textSize="12sp" />
    <TextView android:id="@+id/tv_draft_jumlah" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.5" android:gravity="center" />
    <TextView android:id="@+id/tv_draft_total" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
    <ImageButton
        android:id="@+id/btn_remove_draft"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@drawable/bg_delete"
        android:contentDescription="Hapus item"
        android:padding="7dp"
        android:src="@drawable/ic_delete"
        app:tint="@color/primary_red" />
</LinearLayout>

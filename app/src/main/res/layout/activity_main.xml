<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#F5F6FA"
    tools:context=".activities.dashboard.MainActivity">

    <!-- SIDEBAR -->
    <include
        android:id="@+id/sidebar"
        layout="@layout/layout_sidebar"
        android:layout_width="160dp"
        android:layout_height="match_parent" />

    <!-- KONTEN UTAMA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Garis Pemisah Sidebar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DASHBOARD"
                            android:textColor="#1A1A2E"
                            android:textSize="24sp"
                            android:fontFamily="serif"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_tanggal_header"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#888"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"
                            tools:text="Sabtu, 02 Mei 2026" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ─── BARIS KARTU STATISTIK ─────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Kartu 1: Total Transaksi -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E8ECEF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="20dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_rounded"
                                android:backgroundTint="#EDE7F6"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/shopping_cart"
                                    app:tint="#7B1FA2" />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="14dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Transaksi"
                                    android:textSize="11sp"
                                    android:textColor="#9E9E9E"
                                    android:letterSpacing="0.03" />
                                <TextView
                                    android:id="@+id/tv_total_transaksi"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A1A2E"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Kartu 2: Total Pendapatan -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E8ECEF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="20dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_rounded"
                                android:backgroundTint="#E3F2FD"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/humbleicons_money"
                                    app:tint="#1565C0" />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="14dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Pendapatan"
                                    android:textSize="11sp"
                                    android:textColor="#9E9E9E"
                                    android:letterSpacing="0.03" />
                                <TextView
                                    android:id="@+id/tv_total_pendapatan"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#1565C0"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Kartu 3: Total Pengeluaran -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E8ECEF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="20dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_rounded"
                                android:backgroundTint="#FCE4EC"
                                android:gravity="center">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/solar_wad_of_money_broken"
                                    app:tint="#C62828" />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="14dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Pengeluaran"
                                    android:textSize="11sp"
                                    android:textColor="#9E9E9E"
                                    android:letterSpacing="0.03" />
                                <TextView
                                    android:id="@+id/tv_total_pengeluaran"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#C62828"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ─── TAB FILTER ────────────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="4dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_tab_group"
                    android:padding="4dp">

                    <Button
                        android:id="@+id/btn_tab_pendapatan"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Pendapatan"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="@android:color/transparent"
                        android:textColor="#888"
                        android:layout_marginEnd="4dp"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

                    <Button
                        android:id="@+id/btn_tab_pengeluaran"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Pengeluaran"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="@android:color/transparent"
                        android:textColor="#888"
                        android:layout_marginEnd="4dp"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

                    <Button
                        android:id="@+id/btn_tab_perbandingan"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Perbandingan"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:backgroundTint="@android:color/transparent"
                        android:textColor="#888"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

                </LinearLayout>

                <!-- ─── GRAFIK UTAMA (bisa berubah sesuai tab) ───────────── -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E8ECEF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tv_judul_grafik"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pendapatan Harian (7 Hari Terakhir)"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="#1A1A2E" />

                        <!-- Line Chart (Pendapatan) -->
                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/lineChartPendapatan"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="12dp" />

                        <!-- Bar Chart Pengeluaran (tersembunyi) -->
                        <com.github.mikephil.charting.charts.BarChart
                            android:id="@+id/barChartPengeluaran"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="12dp"
                            android:visibility="gone" />

                        <!-- Bar Chart Perbandingan (tersembunyi) -->
                        <com.github.mikephil.charting.charts.BarChart
                            android:id="@+id/barChartPerbandingan"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="12dp"
                            android:visibility="gone" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ─── GRAFIK BAWAH (Pie + Stok Rendah) ────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">

                    <!-- Pie Chart: Metode Pembayaran -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E8ECEF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="20dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Metode Pembayaran"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1A1A2E" />
                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/pieChartMetode"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card: Produk Stok Rendah -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.2"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E8ECEF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="20dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Stok Hampir Habis"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A1A2E" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="≤ 20 unit"
                                    android:textSize="11sp"
                                    android:textColor="#C62828"
                                    android:background="#20C62828"
                                    android:paddingHorizontal="8dp"
                                    android:paddingVertical="2dp" />
                            </LinearLayout>
                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_stok_rendah"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:nestedScrollingEnabled="false" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Bottom Padding -->
                <View android:layout_width="match_parent" android:layout_height="24dp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</LinearLayout>
